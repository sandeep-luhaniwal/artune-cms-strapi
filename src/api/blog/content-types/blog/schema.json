{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "blogcategories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::blog-category.blog-category",
      "mappedBy": "blog"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "description": {
      "type": "blocks"
    },
    "badge": {
      "type": "string"
    },
    "read_time": {
      "type": "string"
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "shared.content"
      ]
    },
    "publishedDate": {
      "type": "date"
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    }
  }
}
